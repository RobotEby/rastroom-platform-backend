NODE_ENV=production
PORT=8081

# Use the public HTTPS URL of the frontend in staging.
CORS_ORIGIN=https://rastroom-staging.example.com

# Replace user/password/host/db with your staging PostgreSQL credentials.
DATABASE_URL=postgresql://rastroom:CHANGE_ME_DB_PASSWORD@postgres:5432/rastroom?schema=public

# Generate strong values with: openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
